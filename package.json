{
  "name": "world-cup-calendar",
  "version": "0.1.0",
  "private": false,
  "description": "World Cup Calendar is an open-source calendar tool for adding football tournament matches to Google Calendar, Apple Calendar, Outlook, and more.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed": "tsx prisma/seed.ts",
    "db:deploy": "prisma migrate deploy",
    "fixtures:import": "ruby scripts/import-all-fixtures.rb",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "googleapis": "^173.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.19",
    "next-auth": "^4.24.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "$postcss",
    "uuid": "^11.1.1"
  }
}
